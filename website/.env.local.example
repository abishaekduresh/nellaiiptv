NEXT_PUBLIC_API_URL=http://localhost/backend/public/api
APP_ENV=development
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-your-ga-id # Google Analytics
NEXT_PUBLIC_GTM_ID=GTM-your-gtm-id # Google Tag Manager
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# Set to 'true' to disable developer tools (right-click, F12, Ctrl+Shift+I, browser menu)
NEXT_PUBLIC_DISABLE_DEVTOOLS=true

NEXT_PUBLIC_API_SECRET=your-api-secret

# Server-side only vars (used in server components, NOT exposed to browser)
API_URL=http://localhost/nellaiiptv/backend/public/api
API_SECRET=xkey_for_local_dev_only_12345

# Resend email provider (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret used to sign password reset tokens (generate a strong random string)
RESET_TOKEN_SECRET=change_this_to_a_long_random_secret_string

# From email address (must be a verified domain in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Public app URL (used to build reset links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000