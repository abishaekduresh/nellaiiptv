APP_NAME="Nellai IPTV"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:80

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nellai_iptv
DB_USERNAME=root
DB_PASSWORD=

JWT_SECRET=change_this_secret_key_in_production
JWT_EXPIRATION=86400

LOG_CHANNEL=stack
LOG_LEVEL=debug

API_SECRET=your-api-secret

APP_URL=http://localhost/backend/public
FRONTEND_URL=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Cashfree
CASHFREE_APP_ID=your-app-id
CASHFREE_SECRET_KEY=your-secret-key
CASHFREE_MODE=sandbox

MAIL_FROM_ADDRESS=onboarding@resend.dev
RESEND_EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_SKIP_SSL=true

# Secret used to sign password reset tokens (generate a strong random string)
RESET_TOKEN_SECRET=change_this_to_a_long_random_secret_string

# AES-256 key for encrypting MistServer passwords at rest (must be exactly 32 chars)
MIST_ENCRYPTION_KEY=change_this_to_a_strong_32char_key

# From email address (must be a verified domain in Resend)
RESEND_FROM_EMAIL=no-reply@domain.com